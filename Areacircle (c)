#include <stdio.h>

void AreaCircum(float r, float area, double circum) {
    area = 3.1415 * r * r;
    circum = 2 * 3.1415 * r;
     
    printf("Area of circle: %f\n", area);
    printf("Circumference of circle: %f\n", circum);
}

int main() {
    float r, area, circum;

    scanf("%f", &r);

    AreaCircum(r, area, circum);

    return 0;
}
