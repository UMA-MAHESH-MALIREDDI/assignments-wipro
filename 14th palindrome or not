#include <stdio.h>
#include <string.h>

int main(){
    
    char str[500];
    scanf("%s",str);
    
    int len=strlen(str);
    int count=1 ;
    for(int i=0;i<len/2;i++){
        if(str[i]!=str[len-i-1]){
            count=0;
            break;
        }
    }
    if (count){
        printf("plaindrome");
    }
    else{
        printf("not a palindrome");
    }
}
