#include <iostream>
using namespace std;

class Complex {
    int real, imag;

public:
    Complex() {
        real = 0;
        imag = 0;
    }

    Complex(int r, int i) {
        real = r;
        imag = i;
    }

    int getReal() { return real; }
    int getImag() { return imag; }


    void setReal(int r) { real = r; }
    void setImag(int i) { imag = i; }

    void display() {
        cout << real << "+" << imag << "i" << endl;
    }
};

int main() {
    Complex c1;
    Complex c2(3, 4);

    c1.setReal(1);
    c1.setImag(2);

    c1.display();
    c2.display();

    return 0;
}
