#include <iostream>
using namespace std;

class Array {
    int size;
    int *arr;

public:
    // Default constructor
    Array() {
        size = 5;
        arr = new int[size];
        for (int i = 0; i < size; i++)
            arr[i] = 0;
    }

    // Parameterized constructor
    Array(int s) {
        size = s;
        arr = new int[size];
        for (int i = 0; i < size; i++)
            arr[i] = 0;
    }

    // Copy constructor (Deep Copy)
    Array(const Array &a) {
        size = a.size;
        arr = new int[size];
        for (int i = 0; i < size; i++)
            arr[i] = a.arr[i];
    }

    // Accept
    void accept() {
        cout << "Enter " << size << " elements:\n";
        for (int i = 0; i < size; i++)
            cin >> arr[i];
    }

    // Display
    void display() {
        for (int i = 0; i < size; i++)
            cout << arr[i] << " ";
        cout << endl;
    }

    // Destructor
    ~Array() {
        delete[] arr;
    }
};

int main() {
    Array a1;        // default
    Array a2(3);     // parameterized

    a1.accept();
    a2.accept();

    Array a3 = a2;   // copy constructor

    cout << "Array 1: ";
    a1.display();

    cout << "Array 2: ";
    a2.display();

    cout << "Array 3 (Copy of Array 2): ";
    a3.display();

    return 0;
