
#include<stdio.h>

int main(){
    int a[5],i ;
    int max ,min ;
    for (i=0;i<5;i++){
        scanf("%d",&a[i]);
    }
    
    max=a[0];
    min=a[0];
    for (int i=0;i<5;i++)
    {
        if (a[i]>max){
            max=a[i];
        } 
        
        if (a[i]<min){
            min=a[i];
        }
    }
    
    printf("the max value is %d\n",max);
    printf("the min value is %d\n",min);
    
    return 0;
}
