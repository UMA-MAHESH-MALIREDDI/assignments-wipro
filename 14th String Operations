#include <stdio.h>
#include <string.h>
#include <ctype.h>

int countChar(char str[], char ch) {
    int count = 0;
    for(int i=0; str[i]!='\0'; i++) {
        if(tolower(str[i]) == tolower(ch))
            count++;
    }
    return count;
}

int countSpaces(char str[]) {
    int count = 0;
    for(int i=0; str[i]!='\0'; i++)
        if(str[i] == ' ') count++;
    return count;
}

int countWords(char str[]) {
    int count = 1;
    for(int i=0; str[i]!='\0'; i++)
        if(str[i]==' ') count++;
    return count;
}

int countVowels(char str[]) {
    int count = 0;
    for(int i=0; str[i]!='\0'; i++) {
        char ch = str[i];
        if(ch=='a'||ch=='e'||ch=='i'||ch=='o'||ch=='u'||
           ch=='A'||ch=='E'||ch=='I'||ch=='O'||ch=='U')
            count++;
    }
    return count;
}

int main() {
    char str[100], ch;
    fgets(str, sizeof(str), stdin);

    scanf(" %c", &ch);

    printf("Char count: %d\n", countChar(str, ch));
    printf("Spaces: %d\n", countSpaces(str));
    printf("Words: %d\n", countWords(str));
    printf("Vowels: %d\n", countVowels(str));

    return 0;
}
