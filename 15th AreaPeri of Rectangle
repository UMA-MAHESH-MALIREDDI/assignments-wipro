#include<iostream>
using namespace std ;


void Areaperi(int l,int b,int &area,int &peri){
    area=l*b ;
    peri=2*(l+b);
}

int main(){
    int l,b,area,peri; 
    
    cin>>l>>b ;
    Areaperi(l,b,area,peri);
    cout<<"Area of rectangle = "<<area<<endl; 
    cout<<"Perimeter of rectangle = "<<peri<<endl;
    
}
