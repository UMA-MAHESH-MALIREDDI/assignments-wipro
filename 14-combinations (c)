#include <stdio.h>
int main() {
    int arr[]={1,2,3};
    int n=3 ;
    
    for (int i=0;i<n;i++){
        for(int j=0;j<n;j++){
            for(int k=0;k<n;k++){
                if(i!=j && j!=k && 1!=k){
                    printf("%d %d %d\n",arr[i],arr[j],arr[k]);
                }
            }
        }
    }
    return 0;
}
