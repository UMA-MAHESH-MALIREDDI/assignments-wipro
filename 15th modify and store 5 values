#include<iostream>
using namespace std ;

struct Book{
    int book_id ;
    string title;
    float price ;
    
};

void displaybooks(Book b[]){
    for (int i=0;i<5;i++){
        cout<<b[i].book_id<<" "<<b[i].title<<" "<<b[i].price<<"\n" ;
    }
}

int main(){
    Book b[5];
    for (int i=0;i<5;i++){
        cin>>b[i].book_id>>b[i].title>>b[i].price ;
    }
    displaybooks(b);
    return 0;
}
