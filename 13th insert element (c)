#include<stdio.h> 

int main(){
    int n,pos,value ;
    printf("enter array size :\n");
    scanf("%d",&n);
    int arr[n+1];
    printf("enter array : \n");
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    
    printf("enter position\n");
    scanf("%d",&pos);
    printf("enter value \n");
    scanf("%d",&value);
     
    if(pos<1 || pos >n+1){
        
        printf("invalid");
     }
    else{
        for(int i=n; i>=pos;i--){
            arr[i]=arr[i-1] ;
             
             
         }
         arr[pos-1]=value;
         n++;
         
         for(int i=0;i<n;i++){
             
             printf("%d ",arr[i]);
         }
     }
    
    
    
}
