#include<stdio.h>
void minmax(int arr[],int n){
    int min=arr[0];
    int max=arr[0];
    for(int i=0;i<n;i++){
        if(arr[i]<min) min=arr[i];
        if(arr[i]>max) max=arr[i];
        }
        printf("min is %d\n",min);
        printf("max is %d\n",max);
}


void multiply(int arr[],int n){
    int result[5];
    for(int i=0;i<n;i++){
        result[i]=arr[i]*5 ;
        printf("%d ",result[i]);
    }
}

int main(){
    int arr[5];
    for (int i=0;i<5;i++){
        scanf("%d",&arr[i]);
    }
    minmax(arr,5);
    multiply(arr,5);
}
