#include<stdlib.h>
#include <stdio.h>

int main(){
    int n;
    
    float avg=0,sum=0 ;
    scanf("%d",&n);
    int *arr = (int*) malloc(n * sizeof(int));
    
    if (arr==NULL){
        printf("invalid array\n");
        return 1;
    }
    
    for (int i=0;i<n;i++){
        scanf("%d",&arr[i]);
        sum+=arr[i];
    }
    

    avg=sum/n ;
    printf("average is  %.2f \n",avg);
    free(arr);
    return 0;
}
